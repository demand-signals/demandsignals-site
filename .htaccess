# ============================================================
# DEMAND SIGNALS — .htaccess
# ============================================================

Options -Indexes
ServerSignature Off

DirectoryIndex index.php index.html

RewriteEngine On

# ── Always pass static assets directly — no rewriting ────────
RewriteRule \.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot|mp4|pdf)$ - [L]

# Skip real files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# /services/xxx
RewriteRule ^services/([a-z0-9-]+)/?$ /pages/services/$1.php [L]
RewriteRule ^services/?$ /pages/services.php [L]

# /ai-agents/xxx
RewriteRule ^ai-agents/([a-z0-9-]+)/?$ /pages/ai-agents/$1.php [L]
RewriteRule ^ai-agents/?$ /pages/ai-agents.php [L]

# /tools/xxx
RewriteRule ^tools/([a-z0-9-]+)/?$ /pages/tools/$1.php [L]
RewriteRule ^tools/?$ /pages/tools.php [L]

# /blog/slug
RewriteRule ^blog/([a-z0-9_-]+)/?$ /pages/blog/$1.php [L]

# Top-level pages
RewriteRule ^(portfolio|about|blog|contact|easter-egg|privacy|terms|accessibility)/?$ /pages/$1.php [L]

# Utility files
RewriteRule ^robots\.txt$ /api/robots.php [L]
RewriteRule ^sitemap\.xml$ /api/sitemap.php [L]
RewriteRule ^llms\.txt$ /api/llms.php [L]

# Fallback
RewriteRule ^(.*)$ /index.php [L,QSA]

ErrorDocument 404 /404.php

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType video/mp4 "access plus 6 months"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
